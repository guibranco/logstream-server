# ─── Server ───────────────────────────────────────────────────────────────────
HTTP_PORT=8081
WS_PORT=8080
API_SECRET=change-me-to-a-strong-secret

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: "mariadb" | "file"
STORAGE_TYPE=file

# Used when STORAGE_TYPE=file
LOG_PATH=./storage/logs

# Used when STORAGE_TYPE=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=logservice
DB_USER=logservice
DB_PASS=secret
