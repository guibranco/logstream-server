# ─── Server ───────────────────────────────────────────────────────────────────
HTTP_PORT=8081
WS_PORT=8080

# Write key — required on POST /api/logs (your applications use this)
API_SECRET=change-me-to-a-strong-secret

# Read key — required on GET /api/logs and WebSocket connections (your UI uses this)
UI_SECRET=change-me-to-another-strong-secret

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: "mariadb" | "file"
STORAGE_TYPE=file

# Used when STORAGE_TYPE=file
LOG_PATH=./storage/logs

# Used when STORAGE_TYPE=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=logservice
DB_USER=logservice
DB_PASS=secret
