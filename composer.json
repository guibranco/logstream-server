{
  "name": "logservice/logservice",
  "description": "A lightweight log ingestion and streaming service",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "cboden/ratchet": "^0.4",
    "react/http": "^1.9",
    "react/socket": "^1.15",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1.8",
    "ext-pdo_sqlite": "*"
  },
  "autoload": {
    "psr-4": {
      "LogService\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogService\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit --testdox",
    "test:unit": "phpunit --testdox --testsuite unit",
    "test:integration": "phpunit --testdox --testsuite integration"
  }
}
